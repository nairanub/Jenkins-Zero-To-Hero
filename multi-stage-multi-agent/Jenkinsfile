pipeline {
    agent none

    stages {
        stage('Back-end') {
            agent {
                docker { image 'maven:3.8.1-adoptopenjdk-11' }
            }
            steps {
                sh 'mvn --version'
            }
        }

        stage('Front-end') {
            agent {
                docker { image 'node:16-alpine' }
            }
            steps {
                sh 'node --version'
            }
        }

        stage('Database') {
            agent {
                docker {
                    image 'mysql:latest'
                    args '-e MYSQL_ROOT_PASSWORD=root -e MYSQL_DATABASE=testdb -p 3306:3306'
                }
            }
            steps {
                script {
                    echo 'Waiting for MySQL to be ready...'

                    // Get the MySQL container's IP
                    def mysqlIP = sh(
                        script: "docker inspect -f '{{range.NetworkSettings.Networks}}{{.IPAddress}}{{end}}' $(docker ps -q --filter ancestor=mysql:latest)",
                        returnStdout: true
                    ).trim()

                    echo "MySQL Container IP: ${mysqlIP}"

                    // Wait for MySQL to be ready
                    sh """
                        for i in {1..10}; do
                            mysqladmin ping -h ${mysqlIP} -uroot -proot --silent && break
                            echo "Waiting for MySQL to be ready..."
                            sleep 5
                        done
                    """

                    echo 'Verifying database connection...'
                    sh "mysql -h ${mysqlIP} -uroot -proot -e 'SHOW DATABASES;'"
                }
            }
        }
    }
}
